APP_ENV=dev
APP_NAME=polymarket-bot
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=sqlite+pysqlite:///./polymarket_bot.db
REDIS_URL=redis://localhost:6379/0

LIVE_TRADING_ENABLED=false
PAPER_TRADING_ENABLED=true
PANIC_STOP=false

MAX_ORDER_USD=10
MAX_MARKET_EXPOSURE_USD=20
MAX_DAILY_LOSS_USD=30
MIN_EDGE=0.04
MAX_SPREAD=0.02
MIN_DEPTH_USD=50

POLYMARKET_API_BASE=https://example.invalid
POLYMARKET_WSS_BASE=wss://example.invalid/ws
POLYMARKET_PRIVATE_KEY=
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_PASSPHRASE=
